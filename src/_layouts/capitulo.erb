---
layout: default
---

<%
  livro = collections.livros.resources.find { |l| l.data.slug == data.livro_slug }

  capitulos_do_livro = collections.capitulos.resources
                        .select { |c| c.data.livro_slug == data.livro_slug }
                        .sort_by { |c| c.data.ordem.to_i }

  ordem_atual = data.ordem.to_i
  indice_atual = capitulos_do_livro.find_index { |c| c.data.ordem.to_i == ordem_atual }

  anterior = (indice_atual && indice_atual > 0) ? capitulos_do_livro[indice_atual - 1] : nil
  proximo  = (indice_atual && indice_atual < capitulos_do_livro.length - 1) ? capitulos_do_livro[indice_atual + 1] : nil
%>

<article class="capitulo">

  <nav class="breadcrumb">
    <a href="<%= relative_url '/livros/' %>">Livros</a>
    &rsaquo;
    <% if livro %>
      <a href="<%= livro.relative_url %>"><%= livro.data.title %></a>
      &rsaquo;
    <% end %>
    <span>Cap. <%= data.ordem %></span>
  </nav>

  <header class="capitulo__cabecalho">
    <h1><%= data.title %></h1>
    <% if data.tempo_leitura %>
      <p class="capitulo__tempo">
        Tempo de leitura: <strong><%= data.tempo_leitura %></strong>
      </p>
    <% end %>
  </header>

  <div class="capitulo__conteudo">
    <%= yield %>
  </div>

  <footer class="capitulo__rodape">
    <nav class="capitulo__nav">
      <% if anterior %>
        <a href="<%= anterior.relative_url %>">
          &larr; <%= anterior.data.title %>
        </a>
      <% else %>
        <span></span>
      <% end %>

      <% if proximo %>
        <a href="<%= proximo.relative_url %>" class="is-proximo">
          <%= proximo.data.title %> &rarr;
        </a>
      <% else %>
        <span></span>
      <% end %>
    </nav>

    <p class="capitulo__voltar">
      <% if livro %>
        <a href="<%= livro.relative_url %>">&uarr; Voltar ao sumário de <%= livro.data.title %></a>
      <% else %>
        <a href="<%= relative_url '/livros/' %>">&uarr; Todos os livros</a>
      <% end %>
    </p>
  </footer>
</article>
