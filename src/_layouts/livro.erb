---
layout: default
---

<article class="livro">

  <header class="livro__capa">
    <pre>
+---------------------------+
|                           |
|       <%= data.title %>
|                           |
|       por <%= data.autor %>
|                           |
+---------------------------+
    </pre>
    <h1><%= data.title %></h1>
    <p class="livro__autor">por <strong><%= data.autor %></strong> &middot; <%= data.ano %></p>
  </header>

  <section class="livro__descricao">
    <p><em><%= data.descricao %></em></p>
    <%= yield %>
  </section>

  <%
    capitulos_do_livro = collections.capitulos.resources
                          .select { |c| c.data.livro_slug == data.slug }
                          .sort_by { |c| c.data.ordem.to_i }
  %>

  <section class="livro__sumario">
    <h2>Sumário</h2>

    <% if capitulos_do_livro.empty? %>
      <p><em>Nenhum capítulo publicado ainda.</em></p>
    <% else %>
      <ol>
        <% capitulos_do_livro.each do |cap| %>
          <li>
            <a href="<%= cap.relative_url %>">
              <strong><%= cap.data.title %></strong>
            </a>
            <% if cap.data.tempo_leitura %>
              <span class="livro__tempo">&middot; <%= cap.data.tempo_leitura %></span>
            <% end %>
          </li>
        <% end %>
      </ol>

      <div class="livro__cta">
        <a href="<%= capitulos_do_livro.first.relative_url %>">
          Começar pelo Cap. <%= capitulos_do_livro.first.data.ordem %> &rarr;
        </a>
      </div>
    <% end %>
  </section>

  <footer class="livro__rodape">
    <p><a href="<%= relative_url '/livros/' %>">&larr; Todos os livros</a></p>
  </footer>
</article>
